# ─── Provider selection ───────────────────────────────────────
LLM_PROVIDER=foundry                                 # "foundry" (Azure) or "openrouter"
RETRIEVAL_PROVIDER=qdrant                            # "foundry_iq" (Azure AI Search) or "qdrant"

# ─── Azure AI Foundry (Azure OpenAI v1) ───────────────────────
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
AZURE_MODEL_FAST=gpt-4o-mini                         # Foundry deployment name for Agents 1 & 2
AZURE_MODEL_REASONING=gpt-4o                         # Foundry deployment name for Agents 3 & 4

# ─── OpenRouter (fallback path; primary if LLM_PROVIDER=openrouter) ───
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL_A=                                  # fast/cheap model for Agents 1 & 2
OPENROUTER_MODEL_B=                                  # strong reasoning model for Agents 3 & 4
OPENROUTER_FALLBACK=nvidia/nemotron-3-super-120b-a12b:free

# ─── Azure AI Search (backs Foundry IQ; needed when RETRIEVAL_PROVIDER=foundry_iq) ───
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_SEARCH_KEY=...

# ─── Qdrant Cloud (retrieval fallback) ────────────────────────
QDRANT_URL=https://xxxx.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=...

# ─── Neon PostgreSQL ──────────────────────────────────────────
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.aws.neon.tech/pa_agent?sslmode=require

# ─── Agent tuning ─────────────────────────────────────────────
MAX_RETRIES=3

# ─── Optional: LangSmith tracing ──────────────────────────────
LANGCHAIN_TRACING_V2=false
