# ─── OpenRouter ───────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL_A=                                  # fast/cheap model for Agents 1 & 2
OPENROUTER_MODEL_B=                                  # strong reasoning model for Agents 3 & 4
OPENROUTER_FALLBACK=nvidia/nemotron-3-super-120b-a12b:free

# ─── Qdrant Cloud ─────────────────────────────────────────────
QDRANT_URL=https://xxxx.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=...

# ─── Neon PostgreSQL ──────────────────────────────────────────
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.aws.neon.tech/pa_agent?sslmode=require

# ─── Agent tuning ─────────────────────────────────────────────
MAX_RETRIES=3

# ─── Optional: LangSmith tracing ──────────────────────────────
LANGCHAIN_TRACING_V2=false
